# STRATZ API key (required for glyph timestamps)
# Get your free key at https://stratz.com/api
STRATZ_API_KEY=your_stratz_bearer_token_here

# Optional: odota/parser URL for local replay parsing (fallback)
# Only needed if running Docker locally: docker run -p 5600:5600 odota/parser
PARSER_URL=http://localhost:5600
